        information: "████ \n <strong>█████████</strong>" +
            "\n\n ████⠀ ██⠀ ██████⠀ ██████⠀ ████⠀ ████████⠀ ██████⠀ █⠀ █████⠀ ██████⠀ ████⠀ ██████⠀ ███████████⠀ █████⠀ █████⠀ █████████⠀ ████⠀ ██⠀ ███████████████⠀ ██⠀ █████⠀ █████████⠀ ████⠀ █⠀ ████⠀ ███⠀ █████⠀ ███⠀ ███████.",
    }
]

    const art_cards = [
        {
            name: "Sketchfab ↗",
            description: "Here I've posted some of the 3D models I've made over the years",
            url: "https://sketchfab.com/PhantomEye/",
            information: ""
        }, {
            name: "Instagram ↗",
            description: "My art Instagram page, containing some renders, as well as 2D pixel art",
            url: "https://instagram.com/phantomeye1931/",
            information: ""
        }, {
            name: "Contact me",
            description: "I'm available for work, so please reach out!",
            url: "#contact",
            information: ""
        }
    ]
---

<div class="section">
    <div class="projects-websites">
        <section class="column">
            <div class="title" id="projects">Projects</div>
            <div class="grid cols3">
                {
                    projects.map((p) => (
                        <ModalCard title={p.name} description={p.description} information={p.information} buttons={p.buttons} />
                    ))
                }
            </div>
        </section>

        <div class="divider"></div>

        <section class="column">
            <div class="title" id="websites">Websites</div>
            <div class="grid cols2">
                {
                    websites.map((w) => (
                        <ModalCard title={w.name} description={w.description} information={w.information} buttons={w.buttons} /> <!-- classes={w.extra} -->
                    ))
                }
            </div>
        </section>
    </div>
    <div class="art">
        <div class="title" id="art">Art</div>
        <div class="grid art-cards">
            {
                art_cards.map((w) => (
                    <ModalCard title={w.name} description={w.description} information={w.information} />
                ))
            }
        </div>
    </div>
</div>


<style>
.section {
    max-width: 1500px;
    width: 100%;
    margin-inline: auto;
}

.projects-websites {
    display: grid;
    grid-template-columns: 3fr auto 2fr;
    gap: 2rem;
}

.grid {
    display: grid;
    gap: 1rem;
}

.cols2 {
    grid-template-columns: repeat(2, 1fr);
}

.cols3 {
    grid-template-columns: repeat(3, 1fr);
}

.card {
    border: 1px solid var(--col-divider);
    padding: 1rem;
    text-decoration: none;
    color: inherit;
}

.art-cards {
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)) !important;
}

.divider {
    margin-block: 5.5rem 0.5rem;
    width: 1px;
    background-color: var(--col-divider);
    z-index: 1;
}

/* Mobile */
@media (max-width: 1040px) {
    .projects-websites {
        grid-template-columns: 1fr;
    }

    .divider {
        height: 0;
        margin: 0;
    }

    .grid {
        grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
    }
}
</style>
