---
import ModalCard from "../ModalCard.astro";
const projects = [
    {
        name: "PortalMod",
        description: "Portal-inspired technical mod for Minecraft",
        information:
                "2020 - current \n Written in <strong>Java</strong>"

                + "\n\n PortalMod is a big fan project for Minecraft that brings components from the Portal franchise by Valve Software into Minecraft and incorporates them into Minecraft's gameplay loop, artstyle, sound design etc."

                + "\n\n The project has sparked a very active community on its Discord server, growing to more than 5000 members.",
        buttons: [
            { label: "PortalMod Website", url: "https://portalmod.net/" },
            { label: "Discord Community", url: "https://discord.gg/portalmod" }
        ],
    }, {
        name: "GLaDOS Discord Bot",
        description: "Overengineered general-utility and 'fun' Discord bot",
        information:
                "2023 - current \n Stack: <strong>NodeJS, TypeScript</strong>" +

                "\n\n Self-hosted Discord bot framework with functionality for database management, user data storage, user forms, image editing and much more. Has been rewritten a couple of times for a cleaner codebase, using the latest ECMAScript standards and precise typescript patterns." +

                "\n\n To manage the ever-growing Discord community sparked from our PortalMod project, I had to create a Discord bot as a layer to connect our active active userbase with a secure database connection. Since then a lot of new functionality has been added, and it's being updated often.",
        buttons: [
            { label: "Discord Community", url: "https://discord.gg/portalmod" },
            { label: "PortalMod Website", url: "https://github.com/snowy-shack/GLaDOS-Discord-Bot" }
        ],
    }, {
        name: "Efficient chess validation",
        description: "Chess algorithm to evaluate validity of moves statically",
        information:
            "2024 - current \n <strong>Algorithm</strong> & implementation" +

            "\n\n For a passion project, I wanted to implement the game of Chess in Minecraft. However, due to <strong>technical limitations</strong> of Minecraft's scripting language (mcfunction), I had to create <strong>my own efficient strategy to algorithmically determine the state of the board</strong>: which moves are valid, when one of the players has won, and special moves." +

            "\n\n The resulting algorithm can <strong>completely determine which moves are valid</strong> in any given chess position, based on the current state of the board, <strong>without looking ahead in the future</strong>." +

            "\n\n Since I ended up <strong>inventing quite some new (to my research) methods to solve specific problems</strong>, I wrote a blog.",
        buttons: [
            {label: "Read blog", url: "/blog/static-chess-engine"}
        ],
    }, {
        name: "Tic Tac Tesseract",
        description: "Playable tic-tac-toe in 4 dimensions",
        information: "2024 \n Stack: <strong>JavaScript, HTML5 Canvas</strong>" +
            "\n\n Another passion project, with which you can play the timeless classic game of Tic-tac-toe in 4 dimensions! In this surprisingly balanced game, two players can compete on a hyperdimensional game board to get 4 in a row first.",
        buttons: [
            { label: "Play in browser", url: "/pages/tic-tac-tesseract" },
            { label: "Source code", url: "https://github.com/SerialSniper/TicTacTesseract" }
        ],
    }, {
        name: "APF Image format converter",
        description: "Command line utility to convert images to APF",
        information: "2023 \n Written in <strong>Python</strong>" +
            "\n\n A CLI tool to convert to and from the fictional 1-bit Aperture Picture Format image standard, with compression optimized 1980s computers.",
        buttons: [
            { label: "Check out on GitHub", url: "https://github.com/phantomeye1931/APFConverter" }
        ]
    }, {
        name: "Untitled platformer",
        description: "Untitled metroidvania-platformer being developed in Java",
        information: "In development \n Written in <strong>Java</strong>" +
            "\n\n An experimental 2D platformer and metroidvania game with a custom engine built from the ground up with Java, with custom rendering pipelines, input controllers art workflow." +

            "\n\n More info to come.",
        buttons: [
        ]
    }
]

