---
import BusinessCard from "../test/BusinessCard.astro";
---

<div class="section" id="contact">
    <div class="text">
        <div class="title">Get in Touch</div>
        I'm available for new projects and collaborations. Let's build cool things together!
        <br><br>
        If you have anything to share or comment, I would also love to hear about it, my inbox is always open!
    </div>

    <div class="card-wrapper">
        <BusinessCard />
    </div>

    <div class="contact-fallback">
        <!-- Attempt at preventing scraping of email -->
        <div class="item"><strong>Email:</strong> <span>armand.dev</span><span>ries@ou</span><span>tlook.com</span></div>
        <div class="item"><strong>LinkedIn:</strong> <a href="www.linkedin.com/in/armand-devries">@armand-devries</a></div>
        <div class="item"><strong>Discord:</strong> @phantomeye</div>
    </div>
</div>

<style>
    .section {
        display: flex;
        flex-direction: row;
        margin-inline: auto;
        max-width: 1500px;
        margin-block: 2rem;
        gap: 2rem;
    }

    .text {
        padding-block: 2rem;
        flex: 1;
        min-width: 0;
    }

    .contact-fallback {
        display: none;
    }

    @media (max-width: 1000px) {
        .section {
            flex-direction: column;
            gap: 1rem;
        }

        :global(.card-wrapper) {
            display: none;
        }

        .contact-fallback {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            padding: 1.5rem;
            border: 1px solid var(--col-element);

            & a {
                color: var(--col-text-2);
            }
        }
    }
</style>