---
import { getCollection } from 'astro:content';

const blogs = await getCollection('blog');

const posts = blogs
    .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const formatFancy = (date: Date) => {
    return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
};
---

<div class="section" id="weblog">
    <div class="title top-title">Recent weblogs</div>
    Thoughts, write-ups, you name it. Well, I do.

    {
        posts.map((post) => (
            <a href={`/blog/${post.id}`}>
                <div class="item">
                    <div class="header">
                        <div class="title">{post.data.title}</div>
                        <div class="date">
                            {formatFancy(new Date(post.data.pubDate))}
                        </div>
                    </div>
                    <div class="description">{post.data.description}</div>
                </div>
            </a>
        ))
    }
</div>

<style>
.section {
    margin-inline: auto;
    max-width: 1000px;
    margin-block: 2rem;
}

a {
    text-decoration: none;
}

.item {
    position: relative;
    display: flex;
    flex-direction: column;
    color: var(--col-text);
    padding-bottom: 1rem;

    & > * {
        padding-left: 0;
        transition: padding-left 0.3s;
    }

    &::before {
        content: '';
        position: absolute;
        inset: 0;
        background-color: var(--col-text-2);

        width: 0;
        transition: width 0.3s;
    }

    &:hover {
        & > * {
            padding-left: 1.618rem;
        }

        &::before {
            width: 1rem;
        }
    }

    & > .header {
        display: flex;
        align-items: center;
        justify-content: space-between;

        & > .title {
            color: var(--col-element);
            font-family: "Roboto Slab", serif;
            margin-bottom: -0.5rem;
            display: flex;
            width: 100%;

            &::after {
                content: "";
                display: flex;
                border-bottom: 2px solid var(--col-text-3);
                flex: 1;
                margin-inline: 1rem;
                align-self: center;
            }
        }

        & > .date {
            text-wrap: nowrap;
        }
    }

    & > .description {
        margin-right: 2rem;
    }

    @media (max-width: 600px) {
        .header {
            flex-direction: column;
            align-items: flex-start !important;

            & .title {
                line-height: 2.3rem;
                padding-block: 2rem;

                &::after {
                    display: none !important;
                }
            }

            & .date::before {
                content: "☞";
            }
        }
    }
}
</style>